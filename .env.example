# =============================================================================
# Not-ify — Environment Configuration
# =============================================================================
# Copy to .env and customize for your environment.
# Docker Compose automatically loads .env from the project root.

# Server port (default: 3000)
PORT=3000

# Node environment (set by compose overrides, rarely need manual)
# NODE_ENV=production

# Logging level: debug | info | warn | error
LOG_LEVEL=info

# === Privacy (optional) ===
# Route sensitive traffic (ApiBay, Real-Debrid) through VPN sidecar
# Requires --profile vpn in docker compose
# PRIVACY_PROXY=socks5://gluetun:8888

# === VPN (only if using --profile vpn) ===
# PIA_WG_KEY=your-wireguard-private-key
# PIA_REGION=US New York

# === QNAP / NAS ===
# Use polling for file watch on NAS filesystems that lack inotify
# WATCH_MODE=poll

# === GitHub Container Registry (for prod image pulls) ===
GITHUB_USER=illtrick
VERSION=latest
