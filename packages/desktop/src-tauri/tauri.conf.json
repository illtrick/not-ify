{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "Not-ify",
  "version": "0.1.0",
  "identifier": "com.not-ify.app",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../client/dist"
  },
  "app": {
    "title": "Not-ify",
    "windows": [
      {
        "title": "Not-ify",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/USER/not-ify/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
